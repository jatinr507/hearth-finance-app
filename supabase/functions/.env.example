# Secrets for Plaid Edge Functions.
# Local dev: copy to supabase/functions/.env and run `supabase functions serve`.
# Deployed:  set via `supabase secrets set --env-file supabase/functions/.env`
#
# NEVER commit real values. These are server-only — they must never reach the
# browser bundle (do NOT prefix with VITE_).

PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-sandbox-secret
PLAID_ENV=sandbox

# CORS allowlist: comma-separated exact origins permitted to call the functions.
# Include your deployed app origin(s) plus local dev. No wildcard.
# Defaults to http://localhost:5173 if unset.
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# Supabase runtime injects SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY
# automatically when deployed. For local `functions serve` they come from your
# linked project or `supabase start`.
